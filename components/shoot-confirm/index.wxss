.backdrop {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.7);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}
.backdrop.hidden { display: none; }

.modal {
  background: #fff;
  border-radius: 24rpx;
  width: 100%;
  max-width: 640rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.header {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.title { flex: 1; font-size: 30rpx; font-weight: 700; color: #333; }
.close { font-size: 36rpx; color: #999; padding: 0 8rpx; }

.preview {
  width: 100%;
  height: 640rpx;
  background: #000;
  display: block;
}

.actions { display: flex; gap: 16rpx; padding: 24rpx; }
.btn { flex: 1; padding: 20rpx 0; font-size: 28rpx; border-radius: 12rpx; font-weight: 600; }
.btn::after { border: none; }
.btn-retake { background: #f5f5f5; color: #666; }
.btn-submit { background: linear-gradient(135deg, #FF6F00, #FF8F00); color: #fff; }
.btn[disabled] { opacity: 0.6; }

.hint { padding: 0 24rpx 24rpx; font-size: 22rpx; color: #999; text-align: center; }
