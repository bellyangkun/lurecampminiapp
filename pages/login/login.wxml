<!--pages/login/login.wxml - v0.7.8 微信一键登录
  - 顶部品牌区
  - 主按钮: 绿色微信图标"微信一键登录"
  - 次选项: 手机号+验证码 (折叠展开)
-->
<view class="page">
  <!-- 顶部品牌区 -->
  <view class="header">
    <view class="brand-circle">
      <text class="brand-icon">🏕️</text>
    </view>
    <text class="title">乡悦华亭</text>
    <text class="subtitle">登录后享受完整服务</text>
  </view>

  <!-- 主登录卡 -->
  <view class="main-card">
    <view class="main-card-title">微信用户一键登录</view>
    <view class="main-card-tip">授权后自动获取微信头像和昵称, 无需输入手机号</view>

    <!-- 微信一键登录按钮 (用 button 触发 open-type, 真机可用) -->
    <button
      class="wx-login-btn"
      open-type="getPhoneNumber"
      bindgetphonenumber="onWxGetPhone"
      bindtap="onWxLoginTap"
      disabled="{{!agreed || logging}}"
      hover-class="wx-login-btn-active"
    >
      <view class="wx-icon-wrap">
        <text class="wx-icon">💬</text>
      </view>
      <text class="wx-login-text">{{logging ? '登录中...' : '微信一键登录'}}</text>
    </button>

    <!-- 折叠: 手机号登录 (开发模式用, 也可作 fallback) -->
    <view class="divider" bindtap="onTogglePhoneLogin">
      <view class="divider-line"></view>
      <text class="divider-text">{{showPhoneLogin ? '收起' : '其他方式: 手机号登录'}}</text>
      <view class="divider-line"></view>
    </view>

    <view class="phone-form" wx:if="{{showPhoneLogin}}">
      <view class="form-item">
        <view class="input-icon-wrap">
          <text class="input-icon">📱</text>
        </view>
        <input
          class="input"
          type="number"
          maxlength="11"
          placeholder="请输入 11 位手机号"
          value="{{phone}}"
          bindinput="onPhoneInput"
        />
      </view>
      <view class="form-item">
        <view class="input-icon-wrap">
          <text class="input-icon">🔑</text>
        </view>
        <input
          class="input input-code"
          type="number"
          maxlength="6"
          placeholder="请输入验证码"
          value="{{code}}"
          bindinput="onCodeInput"
        />
        <button
          class="send-btn"
          bindtap="onSendCode"
          disabled="{{sending || counting > 0}}"
        >{{counting > 0 ? counting + 's' : (sending ? '发送中' : '获取验证码')}}</button>
      </view>
      <view class="dev-code" wx:if="{{devCode}}">
        <text>🔧 开发模式验证码：</text>
        <text class="dev-code-num">{{devCode}}</text>
      </view>
      <button class="phone-login-btn" bindtap="onPhoneLogin" disabled="{{logging}}">手机号登录 (开发模式)</button>
    </view>
  </view>

  <view class="agreement">
    <view class="checkbox {{agreed ? 'checked' : ''}}" bindtap="onAgreeToggle">
      <view wx:if="{{agreed}}" class="checkbox-inner">✓</view>
    </view>
    <text>我已阅读并同意</text>
    <text class="link" bindtap="onAgreementTap">《用户协议》</text>
    <text>和</text>
    <text class="link" bindtap="onAgreementTap">《隐私政策》</text>
  </view>
</view>
