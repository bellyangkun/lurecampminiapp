<!--pages/login/login.wxml - 登录页 v0.2 重构
  - 顶部品牌区：圆形图标 + 标题/副标题
  - 白色表单卡片
  - 圆形输入图标
  - 底部协议
-->
<view class="page">
  <!-- 顶部品牌区 -->
  <view class="header">
    <view class="brand-circle">
      <text class="brand-icon">🏕️</text>
    </view>
    <text class="title">乡悦华亭</text>
    <text class="subtitle">登录后享受完整服务</text>
  </view>

  <!-- 登录表单卡片 -->
  <view class="form-card">
    <view class="form-title">手机号登录</view>

    <view class="form-item">
      <view class="input-icon-wrap">
        <text class="input-icon">📱</text>
      </view>
      <input
        class="input"
        type="number"
        maxlength="11"
        placeholder="请输入 11 位手机号"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <view class="form-item">
      <view class="input-icon-wrap">
        <text class="input-icon">🔑</text>
      </view>
      <input
        class="input input-code"
        type="number"
        maxlength="6"
        placeholder="请输入验证码"
        value="{{code}}"
        bindinput="onCodeInput"
      />
      <button
        class="send-btn"
        bindtap="onSendCode"
        disabled="{{sending || counting > 0}}"
      >{{counting > 0 ? counting + 's' : (sending ? '发送中' : '获取验证码')}}</button>
    </view>

    <view class="dev-code" wx:if="{{devCode}}">
      <text>🔧 开发模式验证码：</text>
      <text class="dev-code-num">{{devCode}}</text>
    </view>
  </view>

  <button class="login-btn" bindtap="onLogin" disabled="{{logging || !agreed}}">{{logging ? '登录中...' : '立即登录'}}</button>

  <view class="agreement">
    <view class="checkbox {{agreed ? 'checked' : ''}}" bindtap="onAgreeToggle">
      <view wx:if="{{agreed}}" class="checkbox-inner">✓</view>
    </view>
    <text>我已阅读并同意</text>
    <text class="link" bindtap="onAgreementTap">《用户协议》</text>
    <text>和</text>
    <text class="link" bindtap="onAgreementTap">《隐私政策》</text>
  </view>
</view>
