<view class="page">
  <view class="header">
    <text class="title">📱 登录</text>
    <text class="subtitle">手机号 + 验证码</text>
  </view>

  <view class="form">
    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
    </view>
    <view class="form-item">
      <text class="label">验证码</text>
      <input class="input" type="number" maxlength="6" placeholder="6 位验证码" value="{{code}}" bindinput="onCodeInput" />
      <button class="send-btn" bindtap="onSendCode" disabled="{{sending || counting > 0}}">
        {{counting > 0 ? counting + 's' : (sending ? '发送中' : '发送验证码')}}
      </button>
    </view>
    <view class="dev-code" wx:if="{{devCode}}">
      🔧 开发模式验证码: <text class="dev-code-num">{{devCode}}</text>
    </view>
  </view>

  <button class="login-btn" bindtap="onLogin">登 录</button>
</view>
