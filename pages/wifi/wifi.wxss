/* pages/wifi/wifi.wxss - 营地 WiFi 连接页 */
page {
  background: #f5f5f5;
  min-height: 100vh;
}

.page {
  padding: 32rpx;
}

.wifi-card {
  background: linear-gradient(135deg, #2e7d32 0%, #4caf50 100%);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  color: #fff;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(46, 125, 50, 0.25);
}

.wifi-icon {
  font-size: 80rpx;
  line-height: 1;
  margin-bottom: 16rpx;
}

.wifi-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.wifi-desc {
  display: block;
  font-size: 26rpx;
  opacity: 0.92;
}

.info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.info-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-label {
  font-size: 24rpx;
  color: #64748b;
}

.info-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #1e293b;
  font-family: monospace;
}

.info-hint {
  font-size: 22rpx;
  color: #2e7d32;
  background: #e8f5e9;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.connect-btn {
  width: 100%;
  margin-top: 16rpx;
  padding: 26rpx 0;
  background: linear-gradient(135deg, #FF6F00 0%, #FF8F00 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 36rpx;
  box-shadow: 0 6rpx 18rpx rgba(255, 111, 0, 0.3);
}

.connect-btn::after { border: none; }
.connect-btn[disabled] { opacity: 0.7; }

.tips {
  margin-top: 48rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tips-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 16rpx;
}

.tips-item {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.6;
  margin-bottom: 8rpx;
}
