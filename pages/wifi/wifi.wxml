<!--pages/wifi/wifi.wxml - 营地 WiFi 连接页-->
<view class="page">
  <view class="wifi-card">
    <view class="wifi-icon">📶</view>
    <text class="wifi-title">连接营地 WiFi</text>
    <text class="wifi-desc">点击卡片可复制，或尝试一键自动连接</text>
  </view>

  <view class="info-card" bindtap="onCopySsid">
    <view class="info-row">
      <text class="info-label">WiFi 名称</text>
      <text class="info-value">{{ssid}}</text>
    </view>
    <text class="info-hint">点击复制</text>
  </view>

  <view class="info-card" bindtap="onCopyPassword">
    <view class="info-row">
      <text class="info-label">WiFi 密码</text>
      <text class="info-value">{{password}}</text>
    </view>
    <text class="info-hint">点击复制</text>
  </view>

  <button
    class="connect-btn"
    bindtap="onAutoConnect"
    loading="{{connecting}}"
    disabled="{{connecting}}"
  >{{connecting ? '连接中...' : '尝试自动连接'}}</button>

  <!-- 二维码连接（最靠谱的一键方案） -->
  <view class="qr-section" wx:if="{{ssid}}">
    <text class="qr-title">📷 扫码一键连 WiFi</text>
    <canvas
      canvas-id="wifiQrCode"
      class="qr-canvas"
      style="width: 200px; height: 200px;"
    />
    <text class="qr-desc">用系统相机或微信扫一扫识别二维码，即可自动连接 WiFi</text>
  </view>

  <view class="tips">
    <text class="tips-title">提示</text>
    <text class="tips-item">1. 扫码连接：iOS / 安卓系统相机均可识别 WiFi 二维码。</text>
    <text class="tips-item">2. 自动连接：部分安卓机型支持，iPhone 请优先扫码。</text>
    <text class="tips-item">3. 手动连接：复制密码前往「设置 → WLAN」粘贴。</text>
  </view>
</view>
