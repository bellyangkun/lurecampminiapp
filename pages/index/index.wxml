<!--pages/index/index.wxml - 主页: 地图 + 顶部搜索面板 + 右下角 FAB (v0.4 重构)
  布局层级:
  - map          全屏底层
  - overlay-top  顶部搜索面板 (目的地 + 类型过滤 + 路线信息)
  - fab-stack    右下角悬浮按钮 (拍照打卡 + 定位)
  - shoot-confirm 全屏拍照确认面板
-->
<view class="page">
  <!-- 地图 -->
  <map
    id="campMap"
    class="map"
    latitude="{{latitude || 31.481527}}"
    longitude="{{longitude || 121.286954}}"
    markers="{{markers}}"
    polyline="{{polyline}}"
    scale="{{scale || 15}}"
    show-location="{{true}}"
    enable-zoom="{{true}}"
    enable-scroll="{{true}}"
    bindmarkertap="onMarkerTap"
  ></map>

  <!-- 顶部搜索面板 -->
  <view class="overlay-top">
    <!-- 目的地选择器 -->
    <view class="dest-bar">
      <picker mode="selector" range="{{points}}" range-key="name" value="{{selectedDestIdx}}" bindchange="onDestChange">
        <view class="dest-picker">
          <view class="dest-icon" aria-hidden="true">📍</view>
          <view class="dest-text">
            <text class="dest-label">要去哪里？</text>
            <text class="dest-value">{{selectedDestId ? (selectedDestName || '已选') : '选择活动地点'}}</text>
          </view>
          <text class="dest-arrow">▼</text>
        </view>
      </picker>
      <button
        class="end-nav-btn {{endNavBtnShown ? '' : 'hidden'}}"
        bindtap="onEndNavTap"
        style="display:{{endNavBtnShown ? 'flex' : 'none'}}"
        aria-label="结束导航"
      >✕</button>
    </view>

    <!-- 类型过滤 chips -->
    <scroll-view
      class="type-chips"
      scroll-x
      enhanced
      show-scrollbar="{{false}}"
      scroll-with-animation
    >
      <view class="chip-list">
        <view
          wx:for="{{types}}"
          wx:key="key"
          class="chip {{typeFilter === item.key ? 'active' : ''}}"
          data-type="{{item.key}}"
          bindtap="onTypeChipTap"
        >{{item.icon}} {{item.label}}</view>
      </view>
    </scroll-view>

    <!-- 路线信息 (选中目标后显示) -->
    <view class="route-row" wx:if="{{selectedDestId}}">
      <view class="route-stat">
        <text class="route-stat-num">{{distance || '--'}}</text>
        <text class="route-stat-unit">米 · 约 {{walkMins || '--'}} 分钟</text>
      </view>
      <button class="route-action route-walk" bindtap="onWalkNavTap">
        <text class="action-icon">🚶</text>
        <text>路线导航</text>
      </button>
    </view>
  </view>

  <!-- 右下角 FAB 组 -->
  <view class="fab-stack">
    <button class="fab fab-shoot" bindtap="onShootFabTap" hover-class="fab-hover">
      <text class="fab-icon">📷</text>
      <text class="fab-label">拍照打卡</text>
    </button>
    <button class="fab fab-locate" bindtap="onLocateTap" hover-class="fab-hover" aria-label="定位到我">
      <text class="fab-icon">📍</text>
    </button>
  </view>

  <!-- 拍照确认面板 -->
  <shoot-confirm
    visible="{{shootConfirm.visible}}"
    temp-file-path="{{shootConfirm.tempFilePath}}"
    point-name="{{shootConfirm.point ? shootConfirm.point.name : '主动拍照打卡'}}"
    is-other="{{shootConfirm.isOther}}"
    uploading="{{shootConfirm.uploading}}"
    bind:close="onShootClose"
    bind:retake="onShootRetake"
    bind:submit="onShootSubmit"
  />
</view>
