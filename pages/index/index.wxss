/* pages/index/index.wxss - 主页 v0.4 重构
 * 设计方向:
 * - 顶部白色卡片面板: 目的地选择器 + 类型 chips + 路线信息
 * - 右下角 FAB 组: 拍照打卡(橙色大按钮) + 定位(白色小按钮)
 * - 自然露营配色: 深林绿 #2e7d32 / 日落橙 #FF6F00 / 米白背景
 */

page {
  height: 100%;
  background: #f5f5f5;
}

.page {
  position: relative;
  width: 100%;
  height: 100vh;
}

/* ===== 地图: 全屏底层 ===== */
.map {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

/* ===== 顶部搜索面板 ===== */
.overlay-top {
  position: absolute;
  top: calc(32rpx + env(safe-area-inset-top, 0px));
  left: 24rpx;
  right: 24rpx;
  z-index: 10;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(8rpx);
  border-radius: 24rpx;
  padding: 18rpx 20rpx 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(46, 125, 50, 0.08);
}

/* 目的地选择器 */
.dest-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dest-bar picker {
  flex: 1;
  min-width: 0;
  display: block;
}

.dest-picker {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 10rpx 18rpx;
  background: #fff;
  border: 1rpx solid rgba(46, 125, 50, 0.12);
  border-radius: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.dest-icon {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
  border-radius: 50%;
  font-size: 26rpx;
  flex-shrink: 0;
}

.dest-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.dest-label {
  font-size: 20rpx;
  font-weight: 600;
  color: #2e7d32;
  letter-spacing: 0.5rpx;
  line-height: 1.2;
}

.dest-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dest-arrow {
  font-size: 20rpx;
  color: #94a3b8;
  flex-shrink: 0;
  margin-left: 4rpx;
}

.end-nav-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffebee;
  color: #c62828;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 50%;
  flex-shrink: 0;
  transition: transform 0.12s;
}
.end-nav-btn:active { transform: scale(0.92); background: #ffcdd2; }
.end-nav-btn.hidden { display: none !important; }

/* 类型过滤 chips */
.type-chips {
  width: 100%;
  height: 64rpx;
  white-space: nowrap;
}

.chip-list {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  padding: 4rpx 2rpx;
  height: 100%;
  box-sizing: border-box;
}

.chip {
  flex-shrink: 0;
  height: 56rpx;
  line-height: 54rpx;
  padding: 0 22rpx;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 28rpx;
  color: #4a5568;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  white-space: nowrap;
  text-align: center;
  transition: all 0.15s;
}

.chip.active {
  background: #2e7d32;
  color: #fff;
  border-color: #2e7d32;
  box-shadow: 0 4rpx 12rpx rgba(46, 125, 50, 0.28);
  font-weight: 600;
}

.chip:active { transform: scale(0.95); }

/* 路线信息 */
.route-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid #f1f5f9;
}

.route-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.route-stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #2e7d32;
  line-height: 1.1;
  font-variant-numeric: tabular-nums;
}

.route-stat-unit {
  font-size: 20rpx;
  color: #64748b;
}

.route-action {
  flex-shrink: 0;
  height: 64rpx;
  padding: 0 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  white-space: nowrap;
  transition: transform 0.12s;
}

.route-action:active { transform: scale(0.96); }
.route-action::after { border: none; }

.route-walk {
  background: linear-gradient(135deg, #FF6F00, #FF8F00);
  color: #fff;
  box-shadow: 0 4rpx 14rpx rgba(255, 111, 0, 0.35);
}

.action-icon { font-size: 28rpx; line-height: 1; }

/* ===== 底部 FAB 组 ===== */
.fab-stack {
  position: fixed;
  left: 50%;
  bottom: calc(32rpx + env(safe-area-inset-bottom, 0px));
  transform: translateX(-50%);
  z-index: 20;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.fab {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  transition: transform 0.12s, box-shadow 0.15s;
}

.fab-hover { transform: scale(0.95); }
.fab::after { border: none; }

.fab-shoot {
  width: auto;
  min-width: 96rpx;
  height: 72rpx;
  padding: 0 22rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #FF6F00 0%, #FF8F00 100%);
  color: #fff;
  flex-direction: row;
  gap: 8rpx;
  box-shadow:
    0 4rpx 12rpx rgba(255, 111, 0, 0.35),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.25);
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  animation: shootPulse 2.4s ease-in-out infinite;
}

.fab-shoot .fab-icon { font-size: 28rpx; line-height: 1; filter: drop-shadow(0 1rpx 2rpx rgba(0,0,0,0.15)); }
.fab-shoot .fab-label { font-size: 20rpx; font-weight: 700; line-height: 1; text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.15); }

.fab-locate {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f1f8e9 100%);
  color: #2e7d32;
  border: 1rpx solid rgba(46, 125, 50, 0.18);
  box-shadow:
    0 4rpx 12rpx rgba(0, 0, 0, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.fab-locate .fab-icon { font-size: 30rpx; line-height: 1; filter: drop-shadow(0 1rpx 1rpx rgba(0,0,0,0.08)); }

@keyframes shootPulse {
  0%, 100% { box-shadow: 0 4rpx 12rpx rgba(255, 111, 0, 0.35), 0 0 0 0 rgba(255, 111, 0, 0.45); }
  50%      { box-shadow: 0 4rpx 12rpx rgba(255, 111, 0, 0.35), 0 0 0 12rpx rgba(255, 111, 0, 0); }
}
