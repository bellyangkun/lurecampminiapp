/* pages/booking/booking.wxss - 活动预约页 v0.2 重构
 * 设计方向:
 * - 顶部橙渐变头图
 * - 胶囊 tab + 类型筛选 chips
 * - 活动卡片：类型标签、价格突出、日期标签
 * - 我的预约卡片：状态色 + 信息分组
 * - 表单弹窗：白色卡片 + 分组表单
 */

page {
  background: #f5f5f5;
  min-height: 100vh;
}

.page {
  padding-bottom: 32rpx;
}

/* ===== 顶部头图 ===== */
.header {
  background: linear-gradient(135deg, #FF6F00 0%, #FF8F00 100%);
  color: #fff;
  padding: 32rpx 24rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 111, 0, 0.2);
}

.title {
  display: block;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.2;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  opacity: 0.92;
  margin-top: 8rpx;
}

/* ===== Tab 切换 ===== */
.tabs {
  display: flex;
  background: #fff;
  padding: 16rpx;
  gap: 12rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #64748b;
  background: #f1f5f9;
  border-radius: 28rpx;
  font-weight: 500;
  transition: all 0.15s;
}

.tab.active {
  background: linear-gradient(135deg, #FF6F00, #FF8F00);
  color: #fff;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(255, 111, 0, 0.25);
}

/* ===== 类型筛选 ===== */
.kind-filter {
  height: 76rpx;
  background: #fff;
  padding: 0 16rpx 16rpx;
  white-space: nowrap;
  box-sizing: border-box;
}

.kind-list {
  display: inline-flex;
  gap: 12rpx;
  padding: 2rpx 4rpx;
}

.kind-chip {
  flex-shrink: 0;
  height: 56rpx;
  line-height: 54rpx;
  padding: 0 22rpx;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 28rpx;
  color: #4a5568;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  transition: all 0.15s;
}

.kind-chip.active {
  background: #FF6F00;
  color: #fff;
  border-color: #FF6F00;
  box-shadow: 0 4rpx 12rpx rgba(255, 111, 0, 0.25);
}

/* ===== 列表区域 ===== */
.list {
  padding: 24rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 96rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 96rpx;
  line-height: 1;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 8rpx;
}

.empty-text {
  font-size: 24rpx;
  color: #64748b;
}

/* ===== 活动卡片 ===== */
.book-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.book-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.book-kind-tag {
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  align-self: flex-start;
}

.book-kind-tag.activity { background: #e8f5e9; color: #2e7d32; }
.book-kind-tag.catering { background: #fff3e0; color: #e65100; }
.book-kind-tag.hotel { background: #e3f2fd; color: #1565c0; }
.book-kind-tag.event { background: #f3e5f5; color: #7b1fa2; }

.book-cap {
  font-size: 22rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

.book-name {
  font-size: 32rpx;
  font-weight: 800;
  color: #1e293b;
  line-height: 1.3;
  margin-bottom: 8rpx;
}

.book-desc {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.book-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.book-price {
  color: #FF6F00;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1;
}

.price-symbol {
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 2rpx;
}

.price-unit {
  font-size: 22rpx;
  font-weight: 500;
  margin-left: 2rpx;
}

.book-slots {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  justify-content: flex-end;
}

.slot-tag {
  font-size: 20rpx;
  color: #64748b;
  background: #f1f5f9;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}

.book-go {
  width: 100%;
  padding: 18rpx 0;
  background: linear-gradient(135deg, #FF6F00, #FF8F00);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 14rpx rgba(255, 111, 0, 0.25);
}

.book-go::after { border: none; }
.book-go:active { transform: scale(0.98); }

/* ===== 我的预约卡片 ===== */
.mine-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  border-left: 8rpx solid #FF9800;
}

.mine-card.confirmed { border-left-color: #2e7d32; }
.mine-card.cancelled { border-left-color: #9e9e9e; }

.mine-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.mine-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #1e293b;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mine-status-tag {
  font-size: 20rpx;
  font-weight: 600;
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.mine-status-tag.pending { background: #fff3e0; color: #e65100; }
.mine-status-tag.confirmed { background: #e8f5e9; color: #2e7d32; }
.mine-status-tag.cancelled { background: #eeeeee; color: #757575; }

.mine-body {
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 12rpx;
}

.mine-row {
  display: flex;
  font-size: 26rpx;
  padding: 6rpx 0;
}

.mine-label {
  width: 100rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

.mine-value {
  flex: 1;
  color: #1e293b;
  word-break: break-word;
}

.mine-time {
  font-size: 20rpx;
  color: #94a3b8;
  text-align: right;
}

/* ===== 表单弹层 ===== */
.form-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  width: 100%;
  max-width: 660rpx;
  max-height: 90vh;
  overflow-y: auto;
  padding: 28rpx;
  animation: formSlideUp 0.3s ease-out;
}

@keyframes formSlideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to   { transform: translateY(0); opacity: 1; }
}

.form-head {
  display: flex;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f1f5f9;
  margin-bottom: 8rpx;
}

.form-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 800;
  color: #1e293b;
}

.form-close {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #94a3b8;
  background: #f1f5f9;
  border-radius: 50%;
  flex-shrink: 0;
}

.form-section {
  padding: 8rpx 0;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.form-row-top {
  align-items: flex-start;
  padding-top: 22rpx;
}

.form-label {
  width: 110rpx;
  font-size: 28rpx;
  color: #475569;
  font-weight: 600;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #1e293b;
  padding: 8rpx 0;
  min-height: 48rpx;
}

.form-picker {
  color: #1e293b;
}

.form-textarea {
  height: 120rpx;
  width: 100%;
  padding: 8rpx 0;
}

.form-submit {
  width: 100%;
  margin-top: 24rpx;
  padding: 22rpx 0;
  background: linear-gradient(135deg, #FF6F00, #FF8F00);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 111, 0, 0.25);
}

.form-submit::after { border: none; }
.form-submit[disabled] { opacity: 0.6; }
