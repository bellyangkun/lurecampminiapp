page { background: #f5f5f5; }
.page { padding: 24rpx; }
.header { background: linear-gradient(135deg, #FF6F00, #FF8F00); color: #fff; padding: 32rpx 24rpx; border-radius: 16rpx; margin-bottom: 24rpx; }
.title { display: block; font-size: 36rpx; font-weight: 700; }
.subtitle { display: block; font-size: 26rpx; margin-top: 8rpx; opacity: 0.9; }
.num { font-size: 40rpx; font-weight: 700; }

.section-title { font-size: 28rpx; font-weight: 600; margin: 24rpx 0 12rpx; color: #333; }
.empty { text-align: center; color: #999; padding: 48rpx 0; }

.log-item { display: flex; align-items: center; background: #fff; padding: 16rpx; border-radius: 12rpx; margin-bottom: 12rpx; }
.log-main { flex: 1; }
.log-name { display: block; font-size: 28rpx; color: #333; }
.log-time { display: block; font-size: 22rpx; color: #999; margin-top: 4rpx; }
.log-thumb { width: 80rpx; height: 80rpx; border-radius: 8rpx; margin-left: 12rpx; }
