/* pages/checkin/checkin.wxss - 我的打卡页 v0.2 重构
 * 视觉方向:
 * - 顶部橙渐变头图 + 印章大圆环
 * - 白色统计小卡片
 * - 打卡记录卡片化，带序号徽章
 * - 统一露营风配色
 */

page {
  background: #f5f5f5;
  min-height: 100vh;
}

.page {
  padding: 24rpx 24rpx 48rpx;
}

/* ===== 顶部统计头 ===== */
.header {
  position: relative;
  background: linear-gradient(135deg, #FF6F00 0%, #FF8F00 100%);
  color: #fff;
  padding: 40rpx 28rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 24rpx rgba(255, 111, 0, 0.25);
  overflow: hidden;
}

.header::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.header-main {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.2;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  margin-top: 10rpx;
  opacity: 0.92;
  line-height: 1.4;
}

.stamp-circle {
  position: relative;
  z-index: 1;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  border: 4rpx solid rgba(255, 255, 255, 0.4);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 24rpx;
  backdrop-filter: blur(4rpx);
}

.stamp-num {
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1;
}

.stamp-label {
  font-size: 22rpx;
  opacity: 0.9;
  margin-top: 4rpx;
}

/* ===== 统计小卡片 ===== */
.stats-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(0, 0, 0, 0.03);
}

.stat-value {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #2e7d32;
  line-height: 1.1;
  font-variant-numeric: tabular-nums;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-top: 8rpx;
}

/* ===== 最近打卡 ===== */
.latest {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
}

.section-count {
  font-size: 22rpx;
  color: #64748b;
  background: #f1f5f9;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

/* 加载骨架屏 */
.skeleton-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.skeleton-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: #f8fafc;
  border-radius: 16rpx;
}

.skeleton-badge {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e2e8f0;
  flex-shrink: 0;
}

.skeleton-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.skeleton-line {
  height: 22rpx;
  background: #e2e8f0;
  border-radius: 6rpx;
  width: 60%;
}

.skeleton-line.short { width: 40%; }

.skeleton-thumb {
  width: 88rpx;
  height: 88rpx;
  border-radius: 12rpx;
  background: #e2e8f0;
  flex-shrink: 0;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 96rpx;
  line-height: 1;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 8rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.5;
  margin-bottom: 28rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #FF6F00, #FF8F00);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  padding: 18rpx 48rpx;
  border-radius: 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 111, 0, 0.3);
}

.empty-btn::after { border: none; }
.empty-btn:active { transform: scale(0.96); }

/* 打卡列表 */
.log-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.log-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #f8fafc;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid #f1f5f9;
  transition: background 0.15s;
}

.log-item:active { background: #f1f8e9; }

.log-badge {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e8f5e9;
  color: #2e7d32;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 50%;
  flex-shrink: 0;
}

.log-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.log-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.log-time {
  font-size: 22rpx;
  color: #64748b;
}

.log-thumb {
  width: 88rpx;
  height: 88rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #e2e8f0;
}

.log-no-thumb {
  width: 88rpx;
  height: 88rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}
