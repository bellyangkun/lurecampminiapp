/* pages/me/me.wxss - 我的页 v0.2 重构
 * 设计方向:
 * - 顶部绿渐变资料头
 * - 统计卡片重叠在头图下方
 * - 分组菜单卡片
 * - 统一露营风绿/白/灰
 */

page {
  background: #f5f5f5;
  min-height: 100vh;
}

.page {
  padding-bottom: 48rpx;
}

/* ===== 顶部资料头 ===== */
.header {
  position: relative;
  background: linear-gradient(135deg, #2e7d32 0%, #43a047 100%);
  padding: 64rpx 32rpx 80rpx;
  color: #fff;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 260rpx;
  height: 260rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.profile {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar {
  font-size: 64rpx;
  line-height: 1;
}

.info {
  flex: 1;
  min-width: 0;
}

.nickname {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.2;
}

.uid {
  display: block;
  font-size: 22rpx;
  opacity: 0.85;
  margin-top: 8rpx;
  font-family: monospace;
}

.login-btn {
  flex-shrink: 0;
  font-size: 26rpx;
  font-weight: 700;
  padding: 12rpx 28rpx;
  background: #fff;
  color: #2e7d32;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.login-btn::after { border: none; }
.login-btn-active { opacity: 0.9; transform: scale(0.96); }

.login-badge {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 18rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

/* ===== 统计卡片 ===== */
.stats-card {
  display: flex;
  align-items: center;
  margin: -48rpx 24rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 2;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 0;
}

.stat-icon {
  font-size: 36rpx;
  line-height: 1;
  margin-bottom: 4rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #2e7d32;
  line-height: 1.1;
  font-variant-numeric: tabular-nums;
}

.stat-label {
  font-size: 22rpx;
  color: #64748b;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #e2e8f0;
}

.stat-item-active { opacity: 0.8; }

/* ===== 菜单卡片 ===== */
.menu-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 0 24rpx 24rpx;
  padding: 20rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.menu-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #94a3b8;
  padding: 0 28rpx 16rpx;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.menu-group {
  padding: 0 12rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 16rpx;
  border-radius: 12rpx;
  transition: background 0.15s;
}

.menu-item:not(:last-child) {
  border-bottom: 1rpx solid #f1f5f9;
}

.menu-icon {
  font-size: 34rpx;
  line-height: 1;
  width: 44rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 500;
}

.menu-arrow {
  font-size: 36rpx;
  color: #cbd5e1;
  line-height: 1;
}

.menu-extra {
  font-size: 24rpx;
  color: #64748b;
  flex-shrink: 0;
}

.menu-item-active { background: #f8fafc; }

/* ===== 底部信息 ===== */
.footer {
  text-align: center;
  padding: 16rpx 24rpx;
}

.footer-text {
  display: block;
  font-size: 20rpx;
  color: #94a3b8;
  line-height: 1.6;
}
