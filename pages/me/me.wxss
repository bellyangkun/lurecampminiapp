page { background: #f5f5f5; }
.page { padding: 0 0 24rpx; }

.header { background: linear-gradient(135deg, #2e7d32, #4caf50); padding: 48rpx 24rpx; display: flex; align-items: center; gap: 24rpx; color: #fff; }
.avatar { font-size: 80rpx; }
.info { flex: 1; }
.nickname { display: block; font-size: 36rpx; font-weight: 700; }
.uid { display: block; font-size: 22rpx; opacity: 0.8; margin-top: 6rpx; }
.login-btn { font-size: 24rpx; padding: 8rpx 24rpx; background: #fff; color: #2e7d32; border-radius: 30rpx; }
.login-btn::after { border: none; }

.stats { display: flex; gap: 16rpx; padding: 24rpx; }
.stat-item { flex: 1; background: #fff; border-radius: 12rpx; padding: 24rpx; text-align: center; }
.stat-num { display: block; font-size: 44rpx; font-weight: 700; color: #2e7d32; }
.stat-label { display: block; font-size: 22rpx; color: #999; margin-top: 4rpx; }

.menu { background: #fff; margin: 0 24rpx; border-radius: 12rpx; overflow: hidden; }
.menu-item { padding: 28rpx; border-bottom: 1rpx solid #f0f0f0; font-size: 28rpx; color: #333; }
.menu-item:last-child { border-bottom: none; }
