/* pages/me/me.wxss - 我的页 v0.9.0
 * 设计方向:
 * - 柔和绿色渐变头部
 * - 白色内容区上移重叠
 * - 圆角卡片 + 细阴影
 * - 图标色彩区分
 */

page {
  background: #f3f6f4;
  min-height: 100vh;
}

.page {
  padding-bottom: 64rpx;
}

/* ===== 顶部资料头 ===== */
.header {
  position: relative;
  background: linear-gradient(160deg, #2e7d32 0%, #4caf50 60%, #66bb6a 100%);
  padding: 80rpx 32rpx 100rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: -100rpx;
  right: -80rpx;
  width: 360rpx;
  height: 360rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.header-bg::after {
  content: '';
  position: absolute;
  bottom: -120rpx;
  left: -160rpx;
  width: 280rpx;
  height: 280rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

.header-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.avatar-wrap {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  flex-shrink: 0;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  display: block;
  box-sizing: border-box;
}

.avatar-placeholder {
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-emoji {
  font-size: 72rpx;
  line-height: 1;
}

.avatar-edit {
  position: absolute;
  right: 0;
  bottom: 0;
  background: #fff;
  color: #2e7d32;
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(46, 125, 50, 0.2);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.info-wrap {
  flex: 1;
  min-width: 0;
}

.nickname {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.2;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
}

.uid {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  font-family: monospace;
}

.tag {
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.tag-member {
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.35);
}

.tag-guest {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
}

.action-wrap {
  flex-shrink: 0;
}

.btn-login,
.btn-edit {
  font-size: 26rpx;
  font-weight: 700;
  padding: 14rpx 32rpx;
  border-radius: 36rpx;
  line-height: 1.4;
  margin: 0;
}

.btn-login::after,
.btn-edit::after { border: none; }

.btn-login {
  background: #fff;
  color: #2e7d32;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.12);
}

.btn-edit {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.35);
}

.btn-active { opacity: 0.85; transform: scale(0.96); }

/* ===== 数据卡片 ===== */
.stats-section {
  display: flex;
  gap: 20rpx;
  margin: -60rpx 32rpx 28rpx;
  position: relative;
  z-index: 2;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 12rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.15s;
}

.stat-card-active { transform: scale(0.96); opacity: 0.9; }

.stat-num {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #1e3a1e;
  line-height: 1.1;
  font-variant-numeric: tabular-nums;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-top: 8rpx;
}

/* ===== 快捷入口 ===== */
.quick-section {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  background: #fff;
  border-radius: 24rpx;
  margin: 0 32rpx 28rpx;
  padding: 28rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 0;
  border-radius: 16rpx;
  transition: background 0.15s;
}

.quick-item-active { background: #f3f6f4; }

.quick-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.quick-icon.checkin { background: #fff8e1; }
.quick-icon.coupon { background: #e8f5e9; }
.quick-icon.booking { background: #e3f2fd; }
.quick-icon.ai { background: #f3e5f5; }

.quick-text {
  font-size: 24rpx;
  color: #334155;
  font-weight: 500;
}

/* ===== 服务列表 ===== */
.menu-section {
  background: #fff;
  border-radius: 24rpx;
  margin: 0 32rpx 28rpx;
  padding: 24rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
  padding: 0 28rpx 16rpx;
}

.menu-list {
  padding: 0 16rpx;
}

.menu-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 22rpx 16rpx;
  border-radius: 16rpx;
  transition: background 0.15s;
}

.menu-row:not(:last-child) {
  border-bottom: 1rpx solid #f1f5f9;
}

.menu-row-active { background: #f8fafc; }

.menu-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon-wrap.call { background: #e8f5e9; }
.menu-icon-wrap.agreement { background: #fff3e0; }
.menu-icon-wrap.logout { background: #ffebee; }

.menu-icon {
  font-size: 32rpx;
  line-height: 1;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 500;
}

.menu-extra {
  font-size: 24rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

.menu-arrow {
  font-size: 34rpx;
  color: #cbd5e1;
  line-height: 1;
}

.menu-row.logout .menu-text,
.menu-row.logout .menu-arrow,
.menu-row.logout .menu-icon {
  color: #d32f2f;
}

/* ===== 底部信息 ===== */
.footer {
  text-align: center;
  padding: 16rpx 32rpx;
}

.footer-brand {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #475569;
  margin-bottom: 6rpx;
}

.footer-text {
  display: block;
  font-size: 20rpx;
  color: #94a3b8;
  line-height: 1.5;
}
