/* pages/coupons/coupons.wxss - 优惠券页 v0.2 重构
 * 设计方向:
 * - 顶部绿渐变头图
 * - 胶囊 tab
 * - 票券式卡片: 左侧彩色金额区 + 右侧内容区 + 半圆缺口
 * - 统一露营风绿/橙/木色
 */

page {
  background: #f5f5f5;
  min-height: 100vh;
}

.page {
  padding: 24rpx 24rpx 48rpx;
}

/* ===== 顶部头图 ===== */
.header {
  position: relative;
  background: linear-gradient(135deg, #2e7d32 0%, #43a047 100%);
  color: #fff;
  padding: 40rpx 28rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 24rpx rgba(46, 125, 50, 0.25);
  overflow: hidden;
}

.header::before {
  content: '';
  position: absolute;
  top: -50rpx;
  right: -30rpx;
  width: 220rpx;
  height: 220rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.header-main {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.2;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  margin-top: 10rpx;
  opacity: 0.92;
}

.header-icon {
  position: relative;
  z-index: 1;
  font-size: 88rpx;
  line-height: 1;
  margin-left: 20rpx;
}

/* ===== Tab 切换 ===== */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 32rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #64748b;
  border-radius: 24rpx;
  font-weight: 500;
  transition: all 0.15s;
}

.tab.active {
  background: linear-gradient(135deg, #2e7d32, #43a047);
  color: #fff;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(46, 125, 50, 0.25);
}

/* ===== 加载骨架屏 ===== */
.skeleton-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.skeleton-card {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  height: 200rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.skeleton-left {
  width: 200rpx;
  background: #e2e8f0;
  flex-shrink: 0;
}

.skeleton-right {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.skeleton-line {
  height: 24rpx;
  background: #e2e8f0;
  border-radius: 6rpx;
  width: 70%;
}

.skeleton-line.short { width: 40%; }

/* ===== 空状态 ===== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 96rpx;
  line-height: 1;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 8rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 28rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #FF6F00, #FF8F00);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  padding: 18rpx 48rpx;
  border-radius: 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 111, 0, 0.3);
}

.empty-btn::after { border: none; }
.empty-btn:active { transform: scale(0.96); }

/* ===== 优惠券卡片 ===== */
.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.coupon-card {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  position: relative;
}

.coupon-card.mine.used { opacity: 0.7; }

/* 左侧金额区 */
.coupon-left {
  position: relative;
  width: 200rpx;
  flex-shrink: 0;
  padding: 28rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: linear-gradient(135deg, #2e7d32, #43a047);
}

/* 票券缺口 */
.coupon-notch {
  position: absolute;
  right: -18rpx;
  width: 36rpx;
  height: 36rpx;
  background: #f5f5f5;
  border-radius: 50%;
  z-index: 2;
}

.coupon-notch.top { top: -18rpx; }
.coupon-notch.bottom { bottom: -18rpx; }

/* 类型色 */
.coupon-card.discount .coupon-left {
  background: linear-gradient(135deg, #FF6F00, #FF8F00);
}

.coupon-card.gift .coupon-left {
  background: linear-gradient(135deg, #8D6E63, #A1887F);
}

.coupon-card.mine.used .coupon-left {
  background: #9e9e9e;
}

.coupon-amount {
  display: flex;
  align-items: baseline;
  justify-content: center;
  line-height: 1;
}

.amount-symbol {
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 4rpx;
}

.amount-num {
  font-size: 56rpx;
  font-weight: 800;
}

.amount-unit {
  font-size: 24rpx;
  margin-left: 4rpx;
}

.amount-icon {
  font-size: 56rpx;
}

.coupon-condition {
  font-size: 20rpx;
  opacity: 0.92;
  margin-top: 10rpx;
  text-align: center;
}

/* 右侧内容区 */
.coupon-right {
  flex: 1;
  padding: 22rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.coupon-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.coupon-type-tag {
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  align-self: flex-start;
}

.coupon-type-tag.cash { background: #e8f5e9; color: #2e7d32; }
.coupon-type-tag.discount { background: #fff3e0; color: #e65100; }
.coupon-type-tag.gift { background: #efebe9; color: #5d4037; }

.coupon-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  line-height: 1.3;
}

.coupon-desc {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.4;
}

.coupon-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
  padding-top: 8rpx;
}

.coupon-expire {
  font-size: 20rpx;
  color: #94a3b8;
}

.claim-btn {
  background: linear-gradient(135deg, #2e7d32, #43a047);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(46, 125, 50, 0.25);
}

.claim-btn::after { border: none; }
.claim-btn:active { transform: scale(0.96); }

/* 我的券 */
.coupon-code {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  font-size: 24rpx;
  color: #FF6F00;
  font-family: monospace;
  background: #fff3e0;
  padding: 10rpx 14rpx;
  border-radius: 8rpx;
  margin-top: 4rpx;
}

.copy-hint {
  font-size: 20rpx;
  color: #e65100;
  font-family: -apple-system, sans-serif;
  flex-shrink: 0;
}

.coupon-status {
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.coupon-status.used { background: #eeeeee; color: #757575; }
.coupon-status.unused { background: #e8f5e9; color: #2e7d32; }
