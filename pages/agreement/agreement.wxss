/* pages/agreement/agreement.wxss */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #2e7d32, #388e3c);
  color: #fff;
  padding: 40rpx 32rpx;
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

.content {
  flex: 1;
  padding: 24rpx 32rpx;
  background: #fff;
  margin: 16rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2e7d32;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.section-body {
  font-size: 26rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-wrap;
}

.info-type {
  font-weight: 700;
  color: #1b5e20;
  margin-top: 16rpx;
}

.hl {
  color: #d32f2f;
  font-weight: 600;
}

.footer-tip {
  text-align: center;
  color: #999;
  font-size: 22rpx;
  margin-top: 24rpx;
  padding-bottom: 24rpx;
}

.bottom-bar {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 2rpx solid #eee;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.agree-btn {
  flex: 2;
  background: linear-gradient(135deg, #2e7d32, #388e3c);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 50rpx;
  border: none;
  line-height: 80rpx;
  height: 80rpx;
}

.agree-btn::after { border: none; }

.disagree-btn {
  flex: 1;
  background: #f5f5f5;
  color: #666;
  font-size: 28rpx;
  border-radius: 50rpx;
  border: none;
  line-height: 80rpx;
  height: 80rpx;
}

.disagree-btn::after { border: none; }
