/* pages/ai/ai.wxss - AI 客服页 v0.2 重构
 * 设计方向:
 * - 顶部绿渐变头图
 * - 圆形头像
 * - 用户消息绿色渐变气泡，机器人消息白色卡片气泡
 * - 建议问题绿色 chips
 * - 圆角输入栏 + 圆形发送按钮
 */

page {
  background: #f5f5f5;
  height: 100vh;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* ===== 顶部头图 ===== */
.header {
  background: linear-gradient(135deg, #2e7d32 0%, #43a047 100%);
  color: #fff;
  padding: 32rpx 24rpx 24rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.2);
}

.title {
  display: block;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.2;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  opacity: 0.92;
  margin-top: 8rpx;
}

/* ===== 聊天列表 ===== */
.chat-list {
  flex: 1;
  padding: 24rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

.chat-bottom-space {
  height: 24rpx;
}

/* 欢迎卡片 */
.welcome-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
}

.welcome-avatar-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.welcome-avatar {
  font-size: 40rpx;
  line-height: 1;
}

.welcome-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.welcome-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
}

.welcome-text {
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.5;
}

/* 消息行 */
.msg {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.msg.user {
  flex-direction: row-reverse;
}

.msg-avatar-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.msg-avatar-wrap.bot {
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
  margin-right: 16rpx;
}

.msg-avatar-wrap.user {
  background: linear-gradient(135deg, #FF6F00, #FF8F00);
  margin-left: 16rpx;
}

.msg-avatar {
  font-size: 34rpx;
  line-height: 1;
}

/* 气泡 */
.msg-bubble {
  max-width: 70%;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-word;
  white-space: pre-wrap;
  position: relative;
}

.msg.user .msg-bubble {
  background: linear-gradient(135deg, #2e7d32, #43a047);
  color: #fff;
  border-top-right-radius: 4rpx;
  box-shadow: 0 4rpx 12rpx rgba(46, 125, 50, 0.2);
}

.msg.bot .msg-bubble {
  background: #fff;
  color: #333;
  border-top-left-radius: 4rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(0, 0, 0, 0.03);
}

.msg-text {
  display: block;
}

/* 思考中 */
.msg-typing {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 80rpx;
  min-height: 60rpx;
  padding: 16rpx 22rpx;
}

.typing-dots {
  display: inline-flex;
  gap: 8rpx;
}

.typing-dots view {
  width: 10rpx;
  height: 10rpx;
  background: #2e7d32;
  border-radius: 50%;
  animation: typingBounce 1.4s infinite ease-in-out;
}

.typing-dots view:nth-child(2) { animation-delay: 0.2s; }
.typing-dots view:nth-child(3) { animation-delay: 0.4s; }

@keyframes typingBounce {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
  30% { transform: translateY(-8rpx); opacity: 1; }
}

/* 建议问题 */
.suggestions {
  margin-top: 8rpx;
  padding-left: 80rpx;
}

.suggest-title {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 12rpx;
}

.suggest-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.suggest-chip {
  background: #fff;
  border: 1rpx solid #c8e6c9;
  border-radius: 28rpx;
  padding: 10rpx 22rpx;
  font-size: 24rpx;
  color: #2e7d32;
  font-weight: 500;
  transition: all 0.15s;
}

.suggest-chip:active {
  background: #2e7d32;
  color: #fff;
  border-color: #2e7d32;
}

/* ===== 输入栏 ===== */
.input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background: #fff;
  border-top: 1rpx solid #f1f5f9;
  flex-shrink: 0;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom, 0px));
}

.input {
  flex: 1;
  background: #f1f5f9;
  border-radius: 36rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #1e293b;
  min-height: 72rpx;
}

.input-placeholder {
  color: #94a3b8;
}

.send-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2e7d32, #43a047);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(46, 125, 50, 0.25);
  transition: all 0.15s;
}

.send-btn::after { border: none; }

.send-btn.disabled {
  background: #cbd5e1;
  box-shadow: none;
}

.send-btn:not(.disabled):active { transform: scale(0.95); }

.send-icon {
  font-size: 28rpx;
  line-height: 1;
  margin-left: 4rpx;
}
