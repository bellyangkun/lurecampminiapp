<!--pages/ai/ai.wxml - AI 客服页 v0.2 重构
  - 顶部绿渐变头图
  - 圆形头像 + 优化聊天气泡
  - 建议问题 chips
  - 圆角输入栏 + 发送图标按钮
-->
<view class="page">
  <!-- 顶部头图 -->
  <view class="header">
    <view class="header-main">
      <text class="title">🤖 AI 客服</text>
      <text class="subtitle">度假村常见问题，智能回答</text>
    </view>
  </view>

  <!-- 聊天列表 -->
  <scroll-view
    class="chat-list"
    scroll-y="true"
    scroll-into-view="{{scrollIntoView}}"
    scroll-with-animation="true"
    enhanced
    show-scrollbar="{{false}}"
  >
    <!-- 欢迎卡片 -->
    <view class="welcome-card" wx:if="{{messages.length > 0 && messages[0].role === 'bot'}}">
      <view class="welcome-avatar-wrap">
        <text class="welcome-avatar">🤖</text>
      </view>
      <view class="welcome-content">
        <text class="welcome-title">你好，我是小悦</text>
        <text class="welcome-text">有什么可以帮你的吗？试试问我：</text>
      </view>
    </view>

    <!-- 消息列表 -->
    <view
      wx:for="{{messages}}"
      wx:key="ts"
      wx:for-item="msg"
      id="msg-{{msg.ts}}"
      class="msg {{msg.role}}"
    >
      <view class="msg-avatar-wrap {{msg.role}}">
        <text class="msg-avatar">{{msg.role === 'bot' ? '🤖' : '🧑'}}</text>
      </view>
      <view class="msg-bubble">
        <text class="msg-text">{{msg.text}}</text>
      </view>
    </view>

    <!-- 思考中 -->
    <view class="msg bot" wx:if="{{sending}}">
      <view class="msg-avatar-wrap bot">
        <text class="msg-avatar">🤖</text>
      </view>
      <view class="msg-bubble msg-typing">
        <view class="typing-dots">
          <view></view>
          <view></view>
          <view></view>
        </view>
      </view>
    </view>

    <!-- 建议问题 -->
    <view class="suggestions" wx:if="{{messages.length === 1 && !sending}}">
      <text class="suggest-title">💡 试试问我</text>
      <view class="suggest-list">
        <view class="suggest-chip" data-q="营业时间" bindtap="onSuggestTap">营业时间</view>
        <view class="suggest-chip" data-q="地址" bindtap="onSuggestTap">地址</view>
        <view class="suggest-chip" data-q="天幕烧烤" bindtap="onSuggestTap">天幕烧烤</view>
        <view class="suggest-chip" data-q="皮划艇" bindtap="onSuggestTap">皮划艇</view>
        <view class="suggest-chip" data-q="儿童乐园" bindtap="onSuggestTap">儿童乐园</view>
        <view class="suggest-chip" data-q="停车" bindtap="onSuggestTap">停车</view>
      </view>
    </view>

    <!-- 底部占位，避免输入栏遮挡最后一条消息 -->
    <view class="chat-bottom-space"></view>
  </scroll-view>

  <!-- 输入栏 -->
  <view class="input-bar">
    <input
      class="input"
      placeholder="输入问题..."
      value="{{inputText}}"
      bindinput="onInput"
      bindconfirm="sendMessage"
      confirm-type="send"
      cursor-spacing="20"
    />
    <button
      class="send-btn {{!inputText || sending ? 'disabled' : ''}}"
      bindtap="sendMessage"
      disabled="{{sending || !inputText}}"
      aria-label="发送"
    >
      <text class="send-icon">➤</text>
    </button>
  </view>
</view>
