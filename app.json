{
  "pages": [
    "pages/index/index",
    "pages/checkin/checkin",
    "pages/booking/booking",
    "pages/ai/ai",
    "pages/me/me",
    "pages/coupons/coupons",
    "pages/login/login"
  ],
  "window": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "露营地导航",
    "navigationBarBackgroundColor": "#2e7d32",
    "backgroundColor": "#f5f5f5"
  },
  "resizable": false,
  "tabBar": {
    "color": "#999",
    "selectedColor": "#2e7d32",
    "backgroundColor": "#fff",
    "borderStyle": "white",
    "list": [
      { "pagePath": "pages/index/index",   "text": "导航", "iconPath": "images/tab-home.png",     "selectedIconPath": "images/tab-home-on.png" },
      { "pagePath": "pages/checkin/checkin","text": "打卡", "iconPath": "images/tab-checkin.png",  "selectedIconPath": "images/tab-checkin-on.png" },
      { "pagePath": "pages/booking/booking","text": "预约", "iconPath": "images/tab-booking.png",  "selectedIconPath": "images/tab-booking-on.png" },
      { "pagePath": "pages/ai/ai",         "text": "AI",   "iconPath": "images/tab-ai.png",       "selectedIconPath": "images/tab-ai-on.png" },
      { "pagePath": "pages/me/me",          "text": "我的", "iconPath": "images/tab-me.png",       "selectedIconPath": "images/tab-me-on.png" }
    ]
  },
  "style": "v2",
  "componentFramework": "glass-easel",
  "sitemapLocation": "sitemap.json",
  "lazyCodeLoading": "requiredComponents",
  "permission": {
    "scope.userLocation": {
      "desc": "用于显示你的位置, 推荐目的地和路线"
    }
  },
  "requiredPrivateInfos": ["getLocation", "chooseLocation", "onLocationChange", "startLocationUpdate"],
  "__usePrivacyCheck__": true
}
